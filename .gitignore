# NORI .gitignore

# Reference corpora (regenerable via `make data` / `make data-nb` / `make data-nn`;
# large, also avoids redistributing Wikipedia content even under CC-BY-SA)
data/reference/wikipedia_*.jsonl
data/reference/gutenberg_*.jsonl
data/reference/sewiki-*.bz2

# Model generations (regenerable via `make generate`)
data/outputs/
data/outputs_nn/

# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/
.pytest_cache/

# OS
.DS_Store
Thumbs.db

# Editor
.vscode/
.idea/
*.swp

# Logs
logs/
*.log

# Local env
.env
.venv/

# pip install artifacts that land in-tree when running pip without a venv
Lib/
Scripts/
scripts/pytest.exe
scripts/py.test.exe

# Optional paper/whitepaper directory (not part of the benchmark itself)
paper/
